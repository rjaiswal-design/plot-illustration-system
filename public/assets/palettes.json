  "usage_rules": {
    "tint_2": "Specular highlights on glass/metal/glossy surfaces; rim lights",
    "tint_1": "Mid-light planes facing the light; soft fills",
    "base": "Primary fill color of the object — the dominant tone",
    "shade_1": "Cast shadows, side planes, contour edges",
    "shade_2": "Deepest accents — diagonal hatching texture, packaging seams, deep cavities",
    "white": "Logo backgrounds, sharp specular highlights, paper labels",
    "ink": "Logos, line accents (used sparingly)"
  }
